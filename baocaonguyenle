    <script>
        // Lấy các element cần thiết cho Sidebar
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        const sidebarToggle = document.getElementById('sidebar-toggle');
        const toggleIcon = document.getElementById('sidebar-toggle-icon');
        const sidebarTexts = document.querySelectorAll('.sidebar-text');
        
        let isCollapsed = false;

        // Xử lý sự kiện thu gọn Sidebar tổng thể
        sidebarToggle.addEventListener('click', () => {
            isCollapsed = !isCollapsed;
            if (isCollapsed) {
                // Thu nhỏ Sidebar
                sidebar.classList.replace('w-72', 'w-20');
                mainContent.classList.replace('ml-72', 'ml-20');
                toggleIcon.textContent = 'menu';
                
                // Ẩn nội dung văn bản để chỉ hiện thị icon
                sidebarTexts.forEach(el => el.classList.add('hidden'));
            } else {
                // Mở rộng Sidebar
                sidebar.classList.replace('w-20', 'w-72');
                mainContent.classList.replace('ml-20', 'ml-72');
                toggleIcon.textContent = 'menu_open';
                
                // Hiện lại nội dung văn bản
                sidebarTexts.forEach(el => el.classList.remove('hidden'));
            }
        });

        // =========================================================
        // KẾT NỐI APPSHEET API (Bảng tHoso_Chitiet)
        // =========================================================
        const APPSHEET_API_KEY = 'V2-SRMGG-gw3w8-aDuw5-rdyqN-X2xB2-VwDUC-fFWJz-ZbWFX';
        const APPSHEET_APP_ID = 'fecfc0e6-3ff1-4cc2-aa2a-bd32b80f7cd0';
        const TABLE_NAME = 'tHoso_Chitiet';

        async function fetchAppSheetData() {
            const url = `https://api.appsheet.com/api/v2/apps/${APPSHEET_APP_ID}/tables/${TABLE_NAME}/Action`;
            const body = {
                "Action": "Find",
                "Properties": {
                    "Locale": "vi-VN",
                    "Timezone": "Asia/Ho_Chi_Minh"
                },
                "Rows": []
            };

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'ApplicationAccessKey': APPSHEET_API_KEY,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(body)
                });

                if (!response.ok) {
                    throw new Error(`Lỗi HTTP! Trạng thái: ${response.status}`);
                }

                const data = await response.json();
                renderTable(data);
            } catch (error) {
                console.error("Lỗi khi tải dữ liệu AppSheet:", error);
                const tbody = document.getElementById('hoso-table-body');
                if(tbody) {
                    tbody.innerHTML = `<tr><td colspan="5" class="p-md text-center text-error py-4">Lỗi tải dữ liệu: ${error.message} <br/><span class="text-xs text-on-surface-variant font-normal">(Do chính sách bảo mật CORS của trình duyệt, API AppSheet có thể yêu cầu gọi qua server trung gian thay vì gọi trực tiếp từ HTML)</span></td></tr>`;
                }
            }
        }

        function renderTable(rows) {
            const tbody = document.getElementById('hoso-table-body');
            if (!tbody) return;

            tbody.innerHTML = ''; // Xóa thông báo đang tải

            // AppSheet thường trả về mảng trực tiếp nếu thành công
            if (!rows || rows.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="p-md text-center text-on-surface-variant py-4">Không có hồ sơ nào</td></tr>';
                return;
            }

            rows.forEach(row => {
                // ⚠️ LƯU Ý: Đổi tên các trường bên dưới (VD: 'Mã hồ sơ') cho khớp CHÍNH XÁC với tên cột trong bảng tHoso_Chitiet của bạn
                const maHoSo = row['Mã hồ sơ'] || row['Mã Hồ Sơ'] || row['MaHoSo'] || row['_RowNumber']; 
                const tenCongViec = row['Congviec'] || 'Chưa cập nhật';
                const deadline = row['Deadline'] || row['Hạn xử lý'] || row['HanXuLy'] || '-';
                const ngayHoanThanh = row['Ngày hoàn thành'] || row['NgayHoanThanh'] || '-';
                const trangThai = row['Trạng thái'] || row['Trang Thái'] || row['TrangThai'] || 'Đang xử lý';

                // Xác định màu sắc theo trạng thái
                let statusStyle = 'bg-surface-container-high text-on-surface-variant';
                let statusIcon = 'schedule';
                const lowerTrangThai = trangThai.toString().toLowerCase();

                if (lowerTrangThai.includes('đúng hạn') || lowerTrangThai.includes('hoàn thành') || lowerTrangThai.includes('đã xong')) {
                    statusStyle = 'bg-green-100 text-green-800';
                    statusIcon = 'check_circle';
                } else if (lowerTrangThai.includes('trễ') || lowerTrangThai.includes('quá hạn') || lowerTrangThai.includes('lỗi')) {
                    statusStyle = 'bg-error-container text-error';
                    statusIcon = 'warning';
                } else if (lowerTrangThai.includes('đang làm') || lowerTrangThai.includes('đang xử lý')) {
                    statusStyle = 'bg-secondary-container/50 text-on-secondary-container';
                    statusIcon = 'pending_actions';
                }

                const tr = document.createElement('tr');
                tr.className = 'hover:bg-surface-container-high transition-colors';
                tr.innerHTML = `
                    <td class="p-md font-body-md font-semibold text-secondary">${maHoSo}</td>
                    <td class="p-md font-body-md">${tenCongViec}</td>
                    <td class="p-md font-body-md text-on-surface-variant">${deadline}</td>
                    <td class="p-md font-body-md">${ngayHoanThanh}</td>
                    <td class="p-md">
                        <span class="inline-flex items-center gap-xs px-sm py-xs ${statusStyle} text-xs font-bold rounded-full uppercase tracking-tighter">
                            <span class="material-symbols-outlined text-[14px]">${statusIcon}</span> ${trangThai}
                        </span>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        // Tự động gọi API lấy dữ liệu khi tải xong giao diện
        document.addEventListener('DOMContentLoaded', fetchAppSheetData);
    </script>
</body>
</html>
